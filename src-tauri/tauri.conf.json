{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Project Olympus",
  "version": "0.1.0",
  "identifier": "com.projectolympus.commandstation",
  "build": {
    "devUrl": "http://127.0.0.1:31420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Project Olympus",
        "width": 1440,
        "height": 960,
        "minWidth": 1280,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
